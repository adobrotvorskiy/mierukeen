{
  "log": {
    "level": "info",
    "output": "/opt/var/log/sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      { "type": "tcp", "tag": "dns-proxy",  "server": "1.1.1.1",     "detour": "mieru-out" },
      { "type": "udp", "tag": "dns-direct", "server": "192.168.1.1" }
    ],
    "rules": [
      { "rule_set": "geosite-category-ru", "server": "dns-direct" }
    ],
    "final": "dns-proxy",
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "redirect",
      "tag": "tcp-in",
      "listen": "::",
      "listen_port": 7895
    },
    {
      "type": "tproxy",
      "tag": "udp-in",
      "listen": "::",
      "listen_port": 7896,
      "network": "udp",
      "udp_timeout": "5m"
    }
  ],
  "outbounds": [
    { "type": "socks", "tag": "mieru-out", "server": "127.0.0.1", "server_port": 1080, "version": "5" },
    { "type": "direct", "tag": "direct" }
  ],
  "route": {
    "default_domain_resolver": { "server": "dns-direct" },
    "rule_set": [
      {
        "type": "remote", "tag": "geosite-category-ru", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ru.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      },
      {
        "type": "remote", "tag": "geoip-ru", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      },
      {
        "type": "remote", "tag": "geosite-category-ads-all", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      },
      {
        "type": "remote", "tag": "geosite-telegram", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-telegram.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      }
    ],
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "direct" },
      { "rule_set": "geosite-category-ads-all", "action": "reject" },
      { "rule_set": "geosite-telegram", "outbound": "mieru-out" },
      {
        "ip_cidr": [
          "91.105.192.0/23",
          "91.108.4.0/22",
          "91.108.8.0/22",
          "91.108.12.0/22",
          "91.108.16.0/22",
          "91.108.20.0/22",
          "91.108.56.0/22",
          "149.154.160.0/20",
          "185.76.151.0/24"
        ],
        "outbound": "mieru-out"
      },
      { "domain_suffix": ["max.ru", "one.me", "oneme.ru", "tamtam.chat"], "outbound": "direct" },
      { "rule_set": "geosite-category-ru", "outbound": "direct" },
      { "rule_set": "geoip-ru",   "outbound": "direct" }
    ],
    "final": "mieru-out",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/opt/var/lib/sing-box/cache.db",
      "store_fakeip": false
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "CHANGE_ME_CLASH_SECRET"
    }
  }
}
