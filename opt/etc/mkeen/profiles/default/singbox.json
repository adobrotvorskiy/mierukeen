{
  "log": {
    "level": "info",
    "output": "/opt/var/log/sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      { "tag": "dns-proxy",  "address": "tls://1.1.1.1",     "detour": "mieru-out" },
      { "tag": "dns-direct", "address": "https://77.88.8.8/dns-query", "detour": "direct" },
      { "tag": "dns-block",  "address": "rcode://success" }
    ],
    "rules": [
      { "outbound": "any",       "server": "dns-direct" },
      { "rule_set": "geosite-category-ru", "server": "dns-direct" }
    ],
    "final": "dns-proxy",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 7895,
      "sniff": true,
      "sniff_override_destination": true,
      "udp_timeout": "5m"
    }
  ],
  "outbounds": [
    { "type": "socks", "tag": "mieru-out", "server": "127.0.0.1", "server_port": 1080, "version": "5" },
    { "type": "direct", "tag": "direct" },
    { "type": "block",  "tag": "block" },
    { "type": "dns",    "tag": "dns-out" }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote", "tag": "geosite-category-ru", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ru.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      },
      {
        "type": "remote", "tag": "geoip-ru", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      },
      {
        "type": "remote", "tag": "geosite-category-ads-all", "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct",
        "update_interval": "168h"
      }
    ],
    "rules": [
      { "protocol": "dns", "outbound": "dns-out" },
      { "ip_is_private": true, "outbound": "direct" },
      { "rule_set": "geosite-category-ads-all", "outbound": "block" },
      { "rule_set": "geosite-category-ru", "outbound": "direct" },
      { "rule_set": "geoip-ru",   "outbound": "direct" }
    ],
    "final": "mieru-out",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/opt/var/lib/sing-box/cache.db",
      "store_fakeip": false
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "CHANGE_ME_CLASH_SECRET"
    }
  }
}
